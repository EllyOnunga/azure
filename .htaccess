# Azure Bay - Apache Pretty URL Configuration
RewriteEngine On
RewriteBase /

# 1. 301 Redirects from old .html URLs to protect SEO
Redirect 301 /about.html /about/
Redirect 301 /menu.html /menu/
Redirect 301 /order.html /order/
Redirect 301 /contact.html /contact/
Redirect 301 /reserve-table.html /reserve/
Redirect 301 /image-gallery.html /gallery/
Redirect 301 /video-gallery.html /gallery/video/
Redirect 301 /team.html /team/
Redirect 301 /testimonials.html /testimonials/
Redirect 301 /donation.html /donate/
Redirect 301 /faqs.html /faqs/
Redirect 301 /privacy.html /privacy/
Redirect 301 /terms.html /terms/
Redirect 301 /blog.html /blog/
Redirect 301 /blog-ocean-sustainable.html /blog/ocean-sustainable/
Redirect 301 /blog-chef-story.html /blog/chef-story/
Redirect 301 /blog-fish-plate.html /blog/fish-plate/
Redirect 301 /blog-grilling-techniques.html /blog/grilling-techniques/
Redirect 301 /blog-beach-getaway.html /blog/beach-getaway/
Redirect 301 /blog-swahili-spices.html /blog/swahili-spices/
Redirect 301 /team-single.html /team/

# 2. Canonical Trailing Slash Enforcement
# Redirect /about to /about/ (avoids duplicate content and relative path issues)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ $1/ [L,R=301]

# 3. Handle subfolder index files
# Most servers do this by default, but this ensures /about/ loads /about/index.html
DirectoryIndex index.html
